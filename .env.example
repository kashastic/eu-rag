# Copy to .env (gitignored) and fill in. Real env vars override these.

# Enables LLM-written answers; without it EURAG quotes sources verbatim.
ANTHROPIC_API_KEY=

# Optional overrides (defaults shown)
# Answer model: claude-sonnet-5 default ($3/$15 per MTok vs Opus $5/$25);
# claude-haiku-4-5 ($1/$5) works too but hedges more on legal nuance,
# claude-opus-4-8 for maximum answer quality.
# EURAG_LLM_MODEL=claude-sonnet-5
# Low-confidence cascade: when the answer signals insufficient sources,
# retry once with this model over wider retrieval ("none" disables).
# EURAG_ESCALATION_MODEL=claude-opus-4-8
# EURAG_ESCALATION_TOP_K=12
# EURAG_EMBEDDER=fastembed
# EURAG_DATA_DIR=var
# EURAG_TOP_K=6
# QDRANT_URL=
# Cross-encoder reranker ("none" disables; adds ~1s/query, +6pp phrase_hit)
# EURAG_RERANKER=Xenova/ms-marco-MiniLM-L-6-v2
# HyDE query expansion via a cheap model ("none" disables; one Haiku call
# per query, lifts multi-topic question retrieval 67%->100%)
# EURAG_HYDE_MODEL=claude-haiku-4-5
# Multi-hop query decomposition (measured: no gain over HyDE — off by default)
# EURAG_DECOMPOSE_MODEL=none

# --- Security spine (M3) — all off by default = local single-user mode ---
# Require JWT auth and isolate each user's uploads into a private tenant.
# Turn on for multi-user; set a strong JWT secret alongside it.
# EURAG_AUTH_ENABLED=true
# EURAG_JWT_SECRET=<64+ random chars — openssl rand -hex 32>
# AES-256-GCM at-rest encryption of chunk text (64 hex chars = 32 bytes).
# Generate: openssl rand -hex 32
# EURAG_ENCRYPTION_KEY=<64 hex chars>
# PII gate backend for uploads: regex (default, stdlib) or presidio (NER).
# EURAG_PII_BACKEND=regex
