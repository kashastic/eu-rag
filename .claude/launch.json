{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "eurag-api",
      "runtimeExecutable": ".venv/bin/uvicorn",
      "runtimeArgs": ["api.main:app", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "eurag-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "frontend/web"
    }
  ]
}
